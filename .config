CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq50xx=y
CONFIG_TARGET_qualcommax_ipq50xx_DEVICE_generic=y

CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_NAND=y
CONFIG_TARGET_ROOTFS_NAND_SQUASHFS=y

CONFIG_TARGET_MEMORY_256MB=y
CONFIG_TARGET_NAND_128MB=y

# WiFi 驱动
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_ath11k-firmware-qcn6122=y
CONFIG_PACKAGE_wireless-regdb=y

# 无线连接必需
CONFIG_PACKAGE_wpad-basic-wolfssl=y
CONFIG_PACKAGE_iw=y

# 万能中继核心（双频合一输出有线）
CONFIG_PACKAGE_luci-app-relayd=y
CONFIG_PACKAGE_luci-proto-relay=y

# 后台+中文
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# 小工具
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_htop=y

# 默认设置
CONFIG_DEFAULT_HOSTNAME="Repeater"
CONFIG_DEFAULT_PASSWORD="password"
CONFIG_LUCI_LANG_zh-cn=y